{
  "name": "W210",
  "private": true,
  "browserslist": [
    "default"
  ],
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@csstools/normalize.css": "^12.1.1",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.4",
    "eslint": "^10.2.0",
    "markdownlint-cli2": "^0.22.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "stylelint": "^17.5.0",
    "stylelint-config-recommended-scss": "^17.0.0"
  },
  "scripts": {
    "build": "cd exampleSite && hugo --minify",
    "clean": "rm -rf public resources exampleSite/public exampleSite/resources",
    "lint": "npm-run-all --continue-on-error lint:*",
    "lint:markdown": "markdownlint-cli2 *.md content/**/*.md",
    "lint:scripts": "eslint assets/js",
    "lint:styles": "stylelint \"assets/styles/**/*.{css,sass,scss,sss,less}\"",
    "prebuild": "npm run clean",
    "prestart": "npm run clean",
    "start": "cd exampleSite && hugo server --navigateToChanged --buildDrafts --buildFuture --openBrowser",
    "test": "npm run lint",
    "edit": "zed .",
    "dev": "npm-run-all edit start"
  }
}
